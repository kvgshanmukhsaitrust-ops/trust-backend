package com.trustplatform.impact;

import com.trustplatform.impact.dto.ImpactStatResponse;
import lombok.RequiredArgsConstructor;
import org.springframework.security.access.prepost.PreAuthorize;
import org.springframework.web.bind.annotation.*;
import java.util.List;
import java.util.stream.Collectors;

@RestController
@RequestMapping("/api/impact-stats")
@RequiredArgsConstructor
public class ImpactStatController {

    private final ImpactStatRepository repository;

    @GetMapping
    public List<ImpactStatResponse> getAllStats() {
        return repository.findAll().stream()
                .map(stat -> ImpactStatResponse.builder()
                        .id(stat.getId())
                        .category(stat.getCategory())
                        .currentValue(stat.getCurrentValue())
                        .unit(stat.getUnit())
                        .icon(stat.getIcon())
                        .build())
                .collect(Collectors.toList());
    }

    @PutMapping("/{id}")
    @PreAuthorize("hasRole('ADMIN')")
    public ImpactStatResponse updateStat(@PathVariable Long id, @RequestBody Long newValue) {
        ImpactStat stat = repository.findById(id)
                .orElseThrow(() -> new RuntimeException("Stat not found"));

        stat.setCurrentValue(newValue);
        ImpactStat updated = repository.save(stat);

        return ImpactStatResponse.builder()
                .id(updated.getId())
                .currentValue(updated.getCurrentValue())
                .category(updated.getCategory())
                .build();
    }
}