# =============================================================================
# K.V.G Shanmuka Sai Charitable Trust Platform — Environment Variables
# =============================================================================
# Instructions:
#   cp .env.example .env
#   Fill all values below before running docker compose up
#   NEVER commit .env to version control (it's in .gitignore)
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=change_this_strong_root_password
DB_NAME=trustplatform
DB_USER=trustuser
DB_PASSWORD=change_this_strong_db_password

# ── JWT Security ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=change_this_to_a_very_long_random_secret_at_least_64_characters_long

# ── Razorpay Payment Gateway ──────────────────────────────────────────────────
# SANDBOX: Keep as 'dummy' or use Razorpay test keys (rzp_test_...)
# PRODUCTION: Replace with live keys (rzp_live_...) after full testing
# WARNING: Do NOT activate live mode until full regression passes
RAZORPAY_KEY_ID=dummy
RAZORPAY_KEY_SECRET=dummy

# ── Cloudinary Media Storage ──────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Email (SMTP via Gmail App Password) ───────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
# Use Gmail App Password (not account password): https://myaccount.google.com/apppasswords
MAIL_PASSWORD=your_gmail_app_password

# ── AI Providers (optional — leave blank to disable) ─────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── PDF Receipt Storage ───────────────────────────────────────────────────────
# Path inside Docker container — do not change unless customizing volume mounts
APP_RECEIPTS_STORAGE_PATH=/app/receipts
